# ─── Required ───────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/habesha_os"

# Super admin dashboard login
SUPER_ADMIN_EMAIL="your@email.com"
SUPER_ADMIN_PASSWORD="your-secure-password"

# Legacy admin API key (server-to-server / OTP flows). Use a long random string.
ADMIN_KEY="generate-a-long-random-secret-here"

# JWT signing secret — MUST be set in production. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="generate-a-long-random-secret-here"

# Public URL of the deployed app (Chapa callbacks, links)
APP_URL="http://localhost:3000"

# ─── Optional ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Google Gemini — AI business insights
GEMINI_API_KEY=""

# Gmail SMTP — registration / OTP emails
EMAIL_USER=""
EMAIL_PASS=""

# Chapa payment gateway — https://dashboard.chapa.co
CHAPA_SECRET_KEY=""
CHAPA_ENCRYPTION_KEY=""

# SMS notifications (optional)
SMS_API_URL=""
SMS_API_KEY=""
